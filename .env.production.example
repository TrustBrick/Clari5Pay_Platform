# ─────────────────────────────────────────────────────────────────────────────
# Production environment for docker-compose.prod.yml.
# On the EC2 box:  cp .env.production.example .env   then fill in the real values.
# NEVER commit the real .env (it holds secrets). Only this *.example is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database: AWS RDS (Postgres) in the SAME region as this server (ap-south-1) ──
DB_HOST=clari5pay-mumbai.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_rds_master_password
DB_SSL=true
USE_IAM_AUTH=false

# ── App secret (sign JWTs). Generate a fresh 64-char value, do not reuse the demo. ──
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_string

# ── Optional: Claude AI assistant (leave blank to disable the AI chat feature) ──
ANTHROPIC_API_KEY=

# ── Email OTP (production) — Gmail SMTP, sender noreplyclari5pay@gmail.com.
#    When SMTP_HOST is set, login / forgot-password OTPs are emailed for real.
#    SMTP_PASSWORD must be a Gmail App Password for the noreplyclari5pay@gmail.com
#    account (Google Account → Security → 2-Step Verification → App passwords).
#    Set it only here in the un-tracked .env on the server — NEVER commit it.
#    (SMTP_USER also accepts the alias SMTP_USERNAME; SMTP_FROM also accepts EMAIL_FROM.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreplyclari5pay@gmail.com
SMTP_PASSWORD=CHANGE_ME_gmail_app_password
SMTP_FROM=noreplyclari5pay@gmail.com
SMTP_TLS=true

# ── KYC verification (Merchant Portal → KYC Update, Supervisor/Manager only) ──
#    Leave all blank to keep the module inert: the UI renders, input is validated,
#    and verification returns a graceful "not available yet" message. Fill in later
#    (via env only, never hardcode) to connect Melento.ai + DigiLocker — no code/UI
#    change is needed beyond the provider seams in app/services/kyc.py.
MELENTO_API_KEY=
MELENTO_API_ID=
MELENTO_BASE_URL=https://api.melento.ai
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in
