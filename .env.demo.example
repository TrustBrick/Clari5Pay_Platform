# ─────────────────────────────────────────────────────────────────────────────
# Demo/UAT environment for docker-compose.demo.yml (a fully separate EC2 + RDS
# from Production — see DEPLOY_DEMO_AWS.md).
# On the demo EC2 box:  cp .env.demo.example .env   then fill in the real values.
# NEVER commit the real .env (it holds secrets). Only this *.example is committed.
# NEVER reuse Production's DB_PASSWORD, SECRET_KEY, or any other secret below.
# ─────────────────────────────────────────────────────────────────────────────

# Marks this backend as the demo stack: gates POST /api/demo/reset, prefixes OTP
# emails with "[DEMO]", and is echoed on GET /health for deploy verification.
ENVIRONMENT=demo

# ── Database: a SEPARATE AWS RDS instance from Production, same region (ap-south-1) ──
DB_HOST=clari5pay-demo.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_demo_rds_master_password
DB_SSL=true
USE_IAM_AUTH=false

# ── App secret (sign JWTs). Generate a FRESH value — do not reuse Production's. ──
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_string

# ── Optional: Claude AI assistant (leave blank to disable the AI chat feature) ──
ANTHROPIC_API_KEY=

# ── Email OTP — leave SMTP_HOST blank to keep Demo email-free: OTPs are logged to
#    the container console and returned to the client instead, exactly like local
#    dev (see app/core/email.py). Fill these in only once you have a separate
#    sandbox/test mailbox for Demo — never point Demo at Production's SMTP account.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# ── WhatsApp notifications — leave WHATSAPP_PROVIDER blank to keep the feature
#    inert (in-app notifications still work; nothing is sent to a phone). Fill
#    these in only with a separate WhatsApp sandbox/test config — never reuse
#    Production's WHATSAPP_TOKEN. WHATSAPP_COMPANY_NAME brands every message that
#    IS sent once configured, so it's set here even while the feature is inert.
WHATSAPP_PROVIDER=
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_ACCOUNT_SID=
WHATSAPP_TEMPLATE=
WHATSAPP_LANG=en
WHATSAPP_COMPANY_NAME=Clari5Pay DEMO
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── KYC verification (Merchant Portal → KYC Update, Supervisor/Manager only) ──
#    Leave all blank to keep the module inert: the UI renders, input is validated,
#    and verification returns a graceful "not available yet" message. Fill in later
#    (via env only, never hardcode) to connect Melento.ai + DigiLocker — no code/UI
#    change is needed beyond the provider seams in app/services/kyc.py.
MELENTO_API_KEY=
MELENTO_API_ID=
MELENTO_BASE_URL=https://api.melento.ai
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in
