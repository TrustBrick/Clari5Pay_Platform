# Copy this file to `.env` (which is git-ignored) and fill in real values there.
# NEVER put real secrets in this example file — placeholders only.

# ── Database (AWS RDS in production) ──
DB_SSL=true
USE_IAM_AUTH=false
DB_HOST=your-rds-endpoint.<region>.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-rds-master-password

# Local fallback — only used if DB_HOST above is left blank:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5434/clari5pay

REDIS_URL=redis://localhost:6379
# Generate a strong, unique value: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-strong-random-min-32-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ANTHROPIC_API_KEY=your-anthropic-api-key-here
FRONTEND_ORIGIN=http://localhost:3000

# ── SMTP for login / password-reset OTP emails ──
# Leave SMTP_HOST blank for local dev (OTPs are logged to the API console and
# returned to the client as devOtp instead of being emailed).
# For real delivery, use a transactional provider (e.g. Brevo: smtp-relay.brevo.com)
# and put the real SMTP key only in the un-tracked .env — never commit it.
# The sender (SMTP_FROM) must be on a domain you've authenticated (SPF/DKIM) at the
# provider, or mail will be dropped by Gmail/Yahoo/Microsoft.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-key
SMTP_FROM=no-reply@your-domain.com
SMTP_TLS=True
# OTP validity in minutes (spec: 15).
OTP_EXPIRE_MINUTES=15
