# Automatic HTTPS (Let's Encrypt) for Clari5Pay.
# Caddy fetches + renews TLS certs on its own and redirects HTTP -> HTTPS.
# Each domain reverse-proxies to its own frontend nginx container (same codebase,
# built per role), which serves the SPA and proxies /api (+ the chat WebSocket)
# to the shared backend. WebSockets pass through.

# Caddy is the internet edge, so {http.request.remote.host} is the real client's TCP
# address. Overwrite any client-supplied X-Forwarded-For with it, so a forged header can't
# spoof the client IP that downstream rate-limiting / audit logging rely on.
(realclientip) {
	header_up X-Forwarded-For {http.request.remote.host}
}

# Standard security hardening applied to every portal:
#  - a request-body cap (matches nginx's 12 MB) so oversized uploads are dropped at the edge;
#  - HSTS, anti-clickjacking, no MIME sniffing, referrer/permissions policy;
#  - a Content-Security-Policy scoped to what the SPA actually loads (Vite bundle + one inline
#    theme script, Google Fonts, base64/https images, same-origin API + support WebSocket).
#    script/style allow 'unsafe-inline' because the app uses an inline theme script and inline
#    styles; tightening these to a nonce/hash is a follow-up hardening step.
(hardening) {
	request_body {
		max_size 12MB
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' wss: https://ifsc.razorpay.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		-Server
	}
}

# Merchant portal.
win365jackpot.com {
	import hardening
	encode zstd gzip
	reverse_proxy frontend-merchant:3000 {
		import realclientip
	}
}

# Admin portal.
admin.win365jackpot.com {
	import hardening
	encode zstd gzip
	reverse_proxy frontend-admin:3000 {
		import realclientip
	}
}

# Super Admin portal.
sa.win365jackpot.com {
	import hardening
	encode zstd gzip
	reverse_proxy frontend-sa:3000 {
		import realclientip
	}
}

# Combined entry — a chooser that routes users to their portal.
app.win365jackpot.com {
	import hardening
	encode zstd gzip
	reverse_proxy frontend:3000 {
		import realclientip
	}
}

# Customer Support agent portal.
support.win365jackpot.com {
	import hardening
	encode zstd gzip
	reverse_proxy support:3002 {
		import realclientip
	}
}
